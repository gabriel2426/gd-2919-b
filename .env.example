# Copy your Vercel "Secret Snippet" into `.env.local`.
# The database keys below come from your Vercel Postgres / Marketplace Postgres integration.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Optional auth settings for the Next.js dashboard tutorial.
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000/api/auth
